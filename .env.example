# ---- Le Vieillard config (copy to ".env" and fill in) ----
# All optional. Without any provider, breaking digests are printed to the
# console so you can see exactly what WOULD be sent.

# Server
PORT=8132
REFRESH_MIN=8            # how often the website re-fetches feeds (minutes)
PUSH_HOURS=12            # how often the Telegram digest is sent (hours)

# ---- Telegram (easiest, free) ----
# 1. Create a bot via @BotFather → get the token.
# 2. (optional) Create a public channel, add the bot as admin, set its @name below.
# 3. (optional) Set a webhook so /start auto-subscribes users:
#    curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://YOUR_DOMAIN/api/telegram/webhook"
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=          # without @, used for the "open bot" link on the landing page
TELEGRAM_CHANNEL=               # e.g. @levieillard_news  (broadcast target)

# ---- WhatsApp (Meta Cloud API) ----
# From developers.facebook.com → WhatsApp → API Setup.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
