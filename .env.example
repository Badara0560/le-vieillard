# ---- Le Vieillard config (copy to ".env" and fill in) ----
# All optional. Without any provider, breaking digests are printed to the
# console so you can see exactly what WOULD be sent.

# Server
PORT=8132
REFRESH_MIN=8            # how often the website re-fetches feeds (minutes)
PUSH_AT=8,19            # clock hours (UTC) to send the Telegram digest. Mali is on
                        # GMT (UTC+0), so 8,19 = 8am & 7pm local. Comma-separated.

# ---- Weekly newsletter (The West Africa Brief) ----
NEWSLETTER_DAY=1         # day to send: 0=Sun, 1=Mon … 6=Sat (UTC)
NEWSLETTER_HOUR=8        # hour to send (UTC)
# Secret enabling the reliable cron trigger. Pick a long random string, then have
# an external weekly cron (cron-job.org / UptimeRobot) GET this once a week:
#   https://YOUR_DOMAIN/api/newsletter/send?key=YOUR_SECRET
# (add &force=1 to bypass the once-per-week guard for a manual test).
NEWSLETTER_KEY=

# ---- Telegram (easiest, free) ----
# 1. Create a bot via @BotFather → get the token.
# 2. (optional) Create a public channel, add the bot as admin, set its @name below.
# 3. (optional) Set a webhook so /start auto-subscribes users:
#    curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://YOUR_DOMAIN/api/telegram/webhook"
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=          # without @, used for the "open bot" link on the landing page
TELEGRAM_CHANNEL=               # e.g. @levieillard_news  (broadcast target)

# ---- WhatsApp (Meta Cloud API) ----
# From developers.facebook.com → WhatsApp → API Setup.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ---- World Cup dashboard live data (TheSportsDB) ----
# The /worldcup dashboard auto-refreshes the in-progress match from TheSportsDB.
# '3' is the free/test key (limited). A paid key unlocks fuller data.
SPORTSDB_KEY=3
SPORTSDB_WC_LEAGUE=4429   # FIFA World Cup league id on TheSportsDB
